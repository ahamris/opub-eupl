APP_NAME="Open Overheid"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://your-domain.com
APP_LOCALE=nl
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=daily
LOG_LEVEL=error
LOG_DEPRECATIONS_CHANNEL=null
LOG_STACK=single

# Database Configuration
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=open_overheid
DB_USERNAME=your_username
DB_PASSWORD=your_password

# Redis Cache Configuration
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CLIENT=phpredis
CACHE_STORE=redis
REDIS_CACHE_DB=1
REDIS_DB=0

# Session Configuration
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_CONNECTION=default

# Queue Configuration
QUEUE_CONNECTION=redis
REDIS_QUEUE_CONNECTION=default
REDIS_QUEUE=default

# Open Overheid API Configuration
OPEN_OVERHEID_BASE_URL=https://open.overheid.nl/overheid/openbaarmakingen/api/v0
OPEN_OVERHEID_TIMEOUT=10
OPEN_OVERHEID_SYNC_ENABLED=true
OPEN_OVERHEID_SYNC_BATCH_SIZE=50
OPEN_OVERHEID_SYNC_DAYS_BACK=1
OPEN_OVERHEID_USE_LOCAL_SEARCH=true

# Typesense Search Engine Configuration
TYPESENSE_SYNC_ENABLED=true
TYPESENSE_API_KEY=your_typesense_api_key
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http

# Mail Configuration (if needed)
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Broadcasting (if needed)
BROADCAST_DRIVER=log

# Filesystem
FILESYSTEM_DISK=local

# Laravel Boost (Development Only)
BOOST_ENABLED=false
BOOST_BROWSER_LOGS_WATCHER=false
